{
  "name": "jarvis-tts",
  "version": "1.0.0",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "tts": "bun run src/index.ts",
    "tts:on": "scripts/tts-state.sh enable",
    "tts:off": "scripts/tts-state.sh disable",
    "tts:toggle": "scripts/tts-state.sh toggle",
    "tts:status": "scripts/tts-state.sh status",
    "dev": "bun --watch src/index.ts",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "latest",
    "bun-types": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
